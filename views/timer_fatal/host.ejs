<%- include('../partials/header',{root:"../../"}); %>
    <title>Timer Fatal</title>
    </head>

    <body>
        <%- include('../partials/navbarlow'); %>

            <h1 class="text-center display-6 mt-3">Code partie : <%= code %>
            </h1>

            <!-- Pseudo -->
            <div class="row">

                <div class="card col-4 mx-auto" id="user-card">
                    <div class="card-body">
                        <form action="" method="post" id="form-pseudo">
                            <div class="col-xs-4">
                                <input type="hidden" name="code" id="code" value=<%=code %>>
                                <label for="username" class="form-label ">Pseudo</label>
                                <input type="text" name="" id="username" class="form-control" minlength="2"
                                    maxlength="20" placeholder="Saisir votre pseudo" pattern="[a-zA-Z0-9\s]+" required>
                            </div>
                            <button class="btn btn-primary" id="start" type="submit">Rejoindre la partie</button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Options -->
            <div class="text-center">
                <button type="button" class="btn btn-secondary btn-lg mx-auto" id="settings-button" style="display: none;">Options</button>
            </div>
            <div class="row text-center border-top border-bottom mx-auto my-2" id="settings" style="display: none;">
                <h1 class="mx-auto my-2">Options</h1>
                <div class="row mx-auto my-2">
                    <div class="col-4">
                        <p>Temps de départ</p>
                    </div>
                    <div class="col-2">
                        <input type="number" name="" id="timer-fatal-time" class="form-control" minlength="1"
                            maxlength="20" placeholder="Temps pour le départ" value="20" pattern="[0-9\s]+">
                    </div>
                    <div class="col-2">
                        <button type="button" class="btn btn-primary" id="timer-fatal-time-button">Valider</button>
                    </div>
                    <div class="col-4"></div>
                </div>
            </div>

            <!-- Jeu -->
                <div class="container my-4 text-center" id="app-div" style="display: none;">
                    <!-- Ligne 1 : Joueurs 1 à 3 -->
                    <div class="row my-5">
                        <% for (let i=1; i <=3; i++) { %>
                            <div class="col-12 col-md-4">
                                <div class="card mx-auto" style="max-width: 18rem;" id="player-slot-<%= i %>">
                                    <div class="card-header">
                                        <h3 class="h5 mb-0" id="player-name-<%= i %>">Joueur <%= i %>
                                        </h3>
                                    </div>
                                    <div class="card-body">
                                        <span id="player-timer-<%= i %>">00:00</span>
                                    </div>
                                </div>
                            </div>
                            <% } %>
                    </div>
                    <div>
                        <!-- Ligne 2 : Joueur 4 - Buzzer - Joueur 5 -->
                        <div class="row my-5 align-items-center">
                            <div class="col-12 col-md-4">
                                <div class="card mx-auto" style="max-width: 18rem;" id="player-slot-4">
                                    <div class="card-header">
                                        <h3 class="h5 mb-0" id="player-name-4">Joueur 4</h3>
                                    </div>
                                    <div class="card-body">
                                        <span id="player-timer-4">00:00</span>
                                    </div>
                                </div>
                            </div>

                            <div class="col-12 col-md-4 d-flex justify-content-center align-items-center">
                                <svg style="max-width: 200px;" viewBox="0 0 200 200" id="buzzer">
                                    <circle cx="100" cy="100" r="90" stroke="black" stroke-width="4" fill="yellow"
                                        id="buzzer-circle"></circle>
                                    <text x="100" y="110" text-anchor="middle" class="fs-3"
                                        id="buzzer-state">Bloqué</text>
                                </svg>
                            </div>

                            <div class="col-12 col-md-4">
                                <div class="card mx-auto" style="max-width: 18rem;" id="player-slot-5">
                                    <div class="card-header">
                                        <h3 class="h5 mb-0" id="player-name-5">Joueur 5</h3>
                                    </div>
                                    <div class="card-body">
                                        <span id="player-timer-5">00:00</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Ligne 3 : Joueurs 6 à 8 -->
                        <div class="row my-5">
                            <% for (let i=6; i <=8; i++) { %>
                                <div class="col-12 col-md-4">
                                    <div class="card mx-auto" style="max-width: 18rem;" id="player-slot-<%= i %>">
                                        <div class="card-header">
                                            <h3 class="h5 mb-0" id="player-name-<%= i %>">Joueur <%= i %>
                                            </h3>
                                        </div>
                                        <div class="card-body">
                                            <span id="player-timer-<%= i %>">00:00</span>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                        </div>
                    </div>

                    <!-- Boutons -->
                    <div class="text-center my-4">
                        <button type="button" class="btn btn-primary btn-lg" id="btn-start-game">Démarrer la
                            partie</button>
                        <button type="button" class="btn btn-warning btn-lg" style="display: none;" id="btn-stop-timer">Stopper le
                            timer</button>
                        <button type="button" class="btn btn-success btn-lg" style="display: none;" id="btn-restart-timer">Redémarrer le
                                timer</button>
                        <div id="validate-answer" style="display: none;">
                            <button type="button" class="btn btn-warning" id="Faux">Faux (F ou suppr)</button>
                            <button type="button" class="btn btn-success" id="Vrai">Vrai (V ou espace)</button>
                        </div>
                    </div>
                    
                    <div class="modal fade" id="modalGivePoints" data-bs-backdrop="static" data-bs-keyboard="false"
                        tabindex="-1" aria-labelledby="pseudo-modal" aria-hidden="true">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title " id="pseudo-modal">Valider la réponse</h5>
                                </div>
                                <div class="modal-body">
                                    <label for="score" class="form-label" id="modal-score-label">Donnez des points pour la réponse :</label>
                                <input type="number" name="score" id="score-input" class="form-control" placeholder="Nombre de secondes" pattern="[0-9\s]+" required>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" id="btn-validate" data-bs-dismiss="modal">Valider</button>
                                </div>
                            </div>
                        </div>

                    <div class="alert alert-success mt-4 container d-none" id="host-feedback"></div>
                </div>
                
                <%- include('../partials/script'); %>
                <script src="/js/timer_fatalhost.js"></script>
    </body>