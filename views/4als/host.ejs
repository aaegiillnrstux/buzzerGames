      </div>
      <div class="col-4">
        <!-- Buttons -->
        <div id="buttons" class="mx-auto my-2 text-center border-right" style="border-right: 1px solid #ccc">
          <h2>Commandes</h2>
          <button type="button" class="btn btn-warning" id="Faux">Faux (F ou suppr)</button>
          <button type="button" class="btn btn-success" id="Vrai">Vrai (V ou espace)</button>
          <div class="row" id="start-timer" style="display: none">
            <button type="button" class="btn btn-danger" id="Start">Start</button>
            <h2 id="countdown">0</h2>
          </div>
        </div>
      </div>
      <div class="col-4">
        <div id="players-div " class="mx-auto text-center pt-5" style="text-align: center">
          <div class="card mx-auto col-8">
            <div class="card-header">Liste des joueurs</div>
            <div class="card-body">
              <ul class="list-group" id="player-list"></ul>
            </div>
          </div>
        </div>
      </div>
    </div>
    <!-- Validate points -->
    <div
      class="modal fade"
      id="modalGivePoints"
      data-bs-backdrop="static"
      data-bs-keyboard="false"
      tabindex="-1"
      aria-labelledby="pseudo-modal"
      aria-hidden="true"
    >
      <div class="modal-dialog">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="pseudo-modal">Valider la réponse</h5>
          </div>
          <div class="modal-body">
            <label for="score" class="form-label" id="modal-score-label">Donnez des points pour la réponse :</label>
            <input
              type="number"
              name="score"
              id="score-input"
              class="form-control"
              placeholder="Nombre de points"
              pattern="[0-9\s]+"
              required
            />
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" id="btn-validate" data-bs-dismiss="modal">Valider</button>
          </div>
        </div>
      </div>
    </div>

    <%- include('../partials/script'); %>
    <script src="/js/4alshost.js"></script>
  </body>
</html>
