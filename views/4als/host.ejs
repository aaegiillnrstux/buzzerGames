<!DOCTYPE html>
<html lang="fr">
  <head>
    <%- include('../partials/header',{root:"../../"}); %>
    <title>4ALS - Host</title>
  </head>

  <body>
    <%- include('../partials/navbarlow'); %>

    <h1 class="text-center display-4">Game Code: <%= code %></h1>

    <!-- Pseudo -->
    <div class="row">
      <div class="card col-4 mx-auto" id="user-card">
        <div class="card-body">
          <form action="" method="post" id="form-pseudo">
            <div class="col-xs-4">
              <input type="hidden" name="code" id="code" value="<%=code %>" />
              <label for="username" class="form-label">Pseudo</label>
              <input
                type="text"
                name=""
                id="username"
                class="form-control"
                minlength="2"
                maxlength="20"
                placeholder="Saisir votre pseudo"
                pattern="[a-zA-Z0-9]+"
                required
              />
            </div>
            <button class="btn btn-primary" id="start" type="submit">Rejoindre la partie</button>
          </form>
        </div>
      </div>
    </div>

    <!--Options -->
    <div class="text-center">
      <button type="button" class="btn btn-secondary btn-lg mx-auto" style="display: none" id="settings-button">
        Options
      </button>
    </div>
    <div class="row text-center border-top border-bottom mx-auto my-2" id="settings" style="display: none">
      <h1 class="mx-auto my-2">Options</h1>
      <div class="row mx-auto my-2">
        <div class="col-4"><p>Temps de la manche</p></div>
        <div class="col-2">
          <input
            type="number"
            name=""
            id="4als-time"
            class="form-control"
            minlength="1"
            maxlength="20"
            placeholder="Temps pour la manche"
            value="45"
            pattern="[0-9\s]+"
          />
        </div>
        <div class="col-2">
          <button type="button" class="btn btn-primary" id="4als-time-button">Valider</button>
        </div>
        <div class="col-4"></div>
      </div>
    </div>

